# Path to the ExifTool executable.
#
# Windows (Perl script — requires Perl on PATH):
#   EXIFTOOL_PATH=perl C:/Tools/exiftool-master/exiftool
#
# Windows (standalone .exe if you have it):
#   EXIFTOOL_PATH=C:/Tools/exiftool-master/exiftool.exe
#
# macOS / Linux (system-installed):
#   EXIFTOOL_PATH=exiftool
EXIFTOOL_PATH=exiftool
